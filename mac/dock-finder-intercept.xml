<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Label</key>
		<string>com.dock.finder.intercept</string>
		<key>ProgramArguments</key>
		<array>
			<string>/usr/local/bin/dock-finder-intercept</string>
			<string>/Applications/Bloom.app</string>
		</array>
		<key>RunAtLoad</key>
		<true />
		<key>KeepAlive</key>
		<true />
		<key>StandardOutPath</key>
		<string>/tmp/dock-finder-intercept.stdout</string>
		<key>StandardErrorPath</key>
		<string>/tmp/dock-finder-intercept.stderr</string>
	</dict>
</plist>
